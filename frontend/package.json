{
  "name": "alextym-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "npm run sync:project-config",
    "build": "next build",
    "prebuild": "npm run sync:project-config",
    "start": "next start",
    "lint": "eslint .",
    "prelint": "npm run sync:project-config",
    "typecheck": "tsc --noEmit",
    "pretypecheck": "npm run sync:project-config",
    "check:resume": "node scripts/check-resume-parser.mjs",
    "precheck:resume": "npm run sync:project-config",
    "e2e": "playwright test",
    "pree2e": "npm run sync:project-config",
    "e2e:headed": "playwright test --headed",
    "pree2e:headed": "npm run sync:project-config",
    "e2e:install": "playwright install chromium",
    "sync:project-config": "node scripts/sync-project-config.mjs"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
