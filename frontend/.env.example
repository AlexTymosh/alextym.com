# Frontend environment variables
# Used by Next.js rewrites to forward local /api/* frontend requests to the backend.

# Local development backend
BACKEND_ORIGIN=http://localhost:8000

# Vercel Preview/Production deployments must define BACKEND_ORIGIN
# in Vercel Project Settings -> Environment Variables.
# Example:
# BACKEND_ORIGIN=https://alextym-backend.onrender.com
#
# Use only the backend origin. Do not include /api, /health, or any other path.
