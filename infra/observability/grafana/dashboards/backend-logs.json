            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "sum(count_over_time({service=\"portfolio-backend\", environment=~\"${environment:regex}\", level=\"ERROR\"}[$__range]))",
          "queryType": "range",
          "refId": "A"
        }
