          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "sum by (level) (count_over_time({service=\"portfolio-backend\", environment=~\"${environment:regex}\", level=~\"${level:regex}\"}[$__interval]))",
          "legendFormat": "{{level}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Logs by level",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "description": "Top error events parsed from safe structured JSON logs.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "count",
            "axisPlacement": "auto",
