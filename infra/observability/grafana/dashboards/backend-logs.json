          "expr": "topk(10, sum by (event) (count_over_time({service=\"portfolio-backend\", environment=~\"${environment:regex}\", level=\"ERROR\"} | json [$__interval])))",
          "legendFormat": "{{event}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Errors by event",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
