APP_NAME="alextym API"
ENVIRONMENT="local"
FRONTEND_ORIGIN="http://localhost:3000"

SERVICE_NAME="portfolio-backend"
SERVICE_VERSION="0.1.0"
LOG_LEVEL="INFO"
LOG_FORMAT="json"
REQUEST_ID_HEADER="X-Request-ID"

LOG_EXPORT_ENABLED="false"
LOG_EXPORT_MIN_LEVEL="WARNING"
LOKI_PUSH_URL=""
LOKI_USERNAME=""
LOKI_TOKEN=""
LOKI_QUEUE_MAX_SIZE="1000"
LOKI_TIMEOUT_SECONDS="1.5"
LOKI_BATCH_SIZE="50"
LOKI_FLUSH_INTERVAL_SECONDS="2.0"

METRICS_ENABLED="false"
METRICS_TOKEN=""
METRICS_PATH="/internal/metrics"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSIONS="1536"
OPENAI_MAX_OUTPUT_TOKENS="600"
OPENAI_REASONING_EFFORT="low"

QDRANT_URL=""
QDRANT_API_KEY=""
QDRANT_COLLECTION="alex_public_knowledge"

RAG_TOP_K="6"
RAG_SCORE_THRESHOLD="0.4"

RESEND_API_KEY=""
CONTACT_TARGET_EMAIL=""
CONTACT_FROM_EMAIL=""

# Production bot token on deployed backend.
# In local Telegram development, set this to the dev bot token.
TELEGRAM_BOT_TOKEN=""

# Local-only bot token for task dev:telegram.
# Must point to the same dev bot as local TELEGRAM_BOT_TOKEN.
TELEGRAM_DEV_BOT_TOKEN=""

# Username of the local-only dev bot, without @.
# task dev:telegram checks this to avoid using the production bot by mistake.
TELEGRAM_DEV_BOT_USERNAME=""
TELEGRAM_OWNER_CHAT_ID=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_WEBHOOK_URL=""

UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
ESCALATION_SESSION_TTL_SECONDS="7200"

HANDOFF_AVAILABILITY_ENABLED="true"
HANDOFF_AVAILABILITY_TIMEZONE="Europe/London"
HANDOFF_AVAILABILITY_START="09:00"
HANDOFF_AVAILABILITY_END="21:00"

RATE_LIMITING_ENABLED="true"
CHAT_DAILY_LIMIT_PER_IP="50"
CONTACT_DAILY_LIMIT_PER_IP="5"
ESCALATION_DAILY_LIMIT_PER_IP="10"
ESCALATION_MESSAGE_DAILY_LIMIT_PER_IP="50"
